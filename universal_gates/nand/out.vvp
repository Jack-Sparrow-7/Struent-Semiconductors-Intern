S_0x580bf7d2b440 .scope module, "nand_tb" "nand_tb" 2 1;
 .timescale 0 0;
v0x580bf7d3e150_0 .var "a", 0 0;
v0x580bf7d3e1f0_0 .var "b", 0 0;
RS_0x7b98314e20d8 .resolv tri, L_0x580bf7d3e500, L_0x580bf7d3e660, L_0x580bf7d3e750;
v0x580bf7d3e2c0_0 .net8 "out", 0 0, RS_0x7b98314e20d8;  3 drivers, strength-aware
